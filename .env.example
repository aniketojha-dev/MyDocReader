# OpenRouter API Key (Primary LLM Provider)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key (Fallback LLM Provider)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Default LLM model (optional, defaults to meta-llama/llama-3.3-70b-instruct:free)
# See available free models: https://openrouter.ai/models?order=newest&supported_parameters=free
# NEXT_PUBLIC_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free
